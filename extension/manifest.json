{
    "manifest_version": 3,
    "name": "树洞热帖追踪",
    "version": "0.1.0",
    "description": "追踪北京大学树洞实时热帖排行",
    "permissions": ["storage"],
    "host_permissions": ["http://localhost:8765/*"],
    "action": {
        "default_popup": "popup.html",
        "default_title": "树洞热帖"
    },
    "content_scripts": [
        {
            "matches": ["https://treehole.pku.edu.cn/*"],
            "js": ["sidebar.js"]
        }
    ]
}
